<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/grass_dark">

    <!-- Ligne horizontale du terrain (haut) -->
    <View
        android:id="@+id/line_top"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="#33FFFFFF"
        android:layout_marginTop="60dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Ligne horizontale du terrain (bas) -->
    <View
        android:id="@+id/line_bottom"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="#33FFFFFF"
        android:layout_marginBottom="60dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Ligne verticale gauche -->
    <View
        android:id="@+id/line_left"
        android:layout_width="2dp"
        android:layout_height="0dp"
        android:background="#33FFFFFF"
        android:layout_marginStart="24dp"
        app:layout_constraintTop_toBottomOf="@id/line_top"
        app:layout_constraintBottom_toTopOf="@id/line_bottom"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Ligne verticale droite -->
    <View
        android:id="@+id/line_right"
        android:layout_width="2dp"
        android:layout_height="0dp"
        android:background="#33FFFFFF"
        android:layout_marginEnd="24dp"
        app:layout_constraintTop_toBottomOf="@id/line_top"
        app:layout_constraintBottom_toTopOf="@id/line_bottom"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Ligne centrale verticale -->
    <View
        android:id="@+id/line_center_v"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="#44FFFFFF"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <!-- Cercle central du terrain -->
    <View
        android:id="@+id/circle_center"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:background="@drawable/circle_field"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Ballon de foot — positionné dans le tiers supérieur -->
    <ImageView
        android:id="@+id/splash_ball"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/football_ball"
        android:contentDescription="@string/app_name"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/splash_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.38"
        app:layout_constraintVertical_chainStyle="packed"
        android:layout_marginBottom="32dp"/>

    <!-- Titre principal -->
    <TextView
        android:id="@+id/splash_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:fontFamily="sans-serif-black"
        android:textSize="38sp"
        android:letterSpacing="0.05"
        android:textColor="@color/accent_yellow"
        app:layout_constraintTop_toBottomOf="@id/splash_ball"
        app:layout_constraintBottom_toTopOf="@id/splash_tagline"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="10dp"/>

    <!-- Tagline -->
    <TextView
        android:id="@+id/splash_tagline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/splash_tagline"
        android:textSize="14sp"
        android:textColor="#CCFFFFFF"
        android:letterSpacing="0.18"
        android:textAllCaps="true"
        app:layout_constraintTop_toBottomOf="@id/splash_title"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.0"
        android:layout_marginTop="0dp"/>

    <!-- Barre de progression en bas -->
    <ProgressBar
        android:id="@+id/splash_progress"
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:layout_width="160dp"
        android:layout_height="4dp"
        android:indeterminate="true"
        android:progressTint="@color/accent_yellow"
        android:indeterminateTint="@color/accent_yellow"
        android:layout_marginBottom="48dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Version -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="v1.0"
        android:textColor="#66FFFFFF"
        android:textSize="11sp"
        android:layout_marginBottom="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>