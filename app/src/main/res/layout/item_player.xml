<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="@color/bg_card"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp">

    <!-- Bande verte en haut de la card -->
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <View
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:background="@color/grass_dark"/>

        <RelativeLayout
            android:padding="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- ID caché -->
            <TextView
                android:id="@+id/player_id"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone"/>

            <!-- Photo circulaire avec bordure verte -->
            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/player_photo"
                android:layout_width="75dp"
                android:layout_height="75dp"
                android:src="@mipmap/ic_launcher"
                app:civ_border_width="3dp"
                app:civ_border_color="@color/grass_dark"
                android:layout_centerVertical="true"/>

            <!-- Badge position (ex: ATT) -->
            <TextView
                android:id="@+id/player_position"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/player_photo"
                android:layout_marginStart="14dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/badge_position"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:text="ATT"
                android:textColor="@color/accent_white"
                android:textSize="10sp"
                android:textStyle="bold"/>

            <!-- Nom du joueur -->
            <TextView
                android:id="@+id/player_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/player_photo"
                android:layout_below="@id/player_position"
                android:layout_marginStart="14dp"
                android:layout_marginTop="2dp"
                android:text="Nom"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"/>

            <!-- Club -->
            <TextView
                android:id="@+id/player_club"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/player_photo"
                android:layout_below="@id/player_name"
                android:layout_marginStart="14dp"
                android:layout_marginTop="2dp"
                android:text="Club"
                android:textColor="@color/grass_light"
                android:textSize="12sp"/>

            <!-- RatingBar -->
            <RatingBar
                android:id="@+id/player_rating"
                style="?android:attr/ratingBarStyleSmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/player_photo"
                android:layout_below="@id/player_club"
                android:layout_marginStart="14dp"
                android:layout_marginTop="4dp"
                android:numStars="5"
                android:isIndicator="true"
                android:stepSize="0.1"
                android:progressTint="@color/accent_yellow"
                android:secondaryProgressTint="@color/card_border"/>

        </RelativeLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>